# Zephyr Project Configuration for {{ target_name }}
#
# Auto-generated by CompGen targetgen — DO NOT EDIT.
# Target family : {{ family }}
# Deployment    : {{ deployment_model }}

# ---- Core ----
CONFIG_MAIN_STACK_SIZE={{ main_stack_size }}
CONFIG_HEAP_MEM_POOL_SIZE={{ heap_pool_size }}
CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE={{ workqueue_stack_size }}

# ---- Threading ----
CONFIG_MULTITHREADING=y
CONFIG_NUM_PREEMPT_PRIORITIES=16
CONFIG_TIMESLICING=y
CONFIG_SCHED_MULTIQ=y

# ---- Memory ----
CONFIG_KERNEL_MEM_POOL=y
{% if dma_model != "none" %}
# ---- DMA ----
CONFIG_DMA=y
{% endif %}
{% if has_semaphores %}
# ---- Synchronization ----
CONFIG_POLL=y
{% endif %}

# ---- Logging ----
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=3

# ---- Custom ----
{% for key, value in extra_config.items() %}
{{ key }}={{ value }}
{% endfor %}
