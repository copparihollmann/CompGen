/*
 * Device Tree Source Overlay for {{ target_name }}
 *
 * Auto-generated by CompGen targetgen — DO NOT EDIT.
 * Target family : {{ family }}
 */

/ {
    chosen {
        zephyr,console = &uart0;
        zephyr,shell-uart = &uart0;
    };

{% for space in address_spaces %}
    {{ space.name }}: {{ space.name }}@{{ "%x" | format(space.base_address) }} {
        compatible = "mmio-sram";
        reg = <0x{{ "%08x" | format(space.base_address) }} 0x{{ "%08x" | format(space.size_bytes) }}>;
        label = "{{ space.name | upper }}";
{% if space.dma_accessible %}
        zephyr,memory-attr = <DT_MEM_DMA>;
{% endif %}
    };

{% endfor %}
};
