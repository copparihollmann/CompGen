# CompGen Generated Compiler - Dockerfile
# Auto-generated by CompGen mlir_cppgen
#
# Build:
#   docker build -t compgen-compiler .
#
# Usage:
#   docker run -v $(pwd):/work compgen-compiler compgen-opt /work/input.mlir
#

# Stage 1: Build LLVM/MLIR
FROM ubuntu:22.04 AS llvm-builder

RUN apt-get update && apt-get install -y \
    cmake ninja-build clang lld python3 \
    && rm -rf /var/lib/apt/lists/*

COPY {{ llvm_dir }} /llvm-project

RUN cmake -G Ninja -S /llvm-project/llvm -B /llvm-build \
    -DLLVM_ENABLE_PROJECTS=mlir \
    -DLLVM_TARGETS_TO_BUILD="host" \
    -DCMAKE_BUILD_TYPE=Release \
    -DLLVM_ENABLE_ASSERTIONS=ON \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DLLVM_USE_LINKER=lld

RUN ninja -C /llvm-build -j$(nproc)

# Stage 2: Build CompGen compiler
FROM llvm-builder AS compgen-builder

COPY . /compgen-compiler

RUN cmake -G Ninja -S /compgen-compiler -B /compgen-build \
    -DMLIR_DIR=/llvm-build/lib/cmake/mlir \
    -DLLVM_DIR=/llvm-build/lib/cmake/llvm \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang++ \
    -DLLVM_USE_LINKER=lld

RUN ninja -C /compgen-build -j$(nproc)

# Stage 3: Runtime image
FROM ubuntu:22.04

COPY --from=compgen-builder /compgen-build/bin/compgen-opt /usr/local/bin/
COPY --from=compgen-builder /compgen-build/lib/ /usr/local/lib/

RUN ldconfig

ENTRYPOINT ["compgen-opt"]
